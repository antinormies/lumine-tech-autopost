# LLM Server (vision model)
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=Qwen2.5-3B

# Twitter Browser Session
TWITTER_USERNAME=
TWITTER_PASSWORD=
TWITTER_EMAIL=

# Browser mode (choose one):
# Option 1: Launch new browser
BROWSER_HEADLESS=false
# Option 2: Use persistent profile (saves all state between runs)
# BROWSER_USER_DATA_DIR=./chrome_profile
# For Brave snap browser, point to the profile dir (parent of Default/):
# BROWSER_USER_DATA_DIR=/home/dani/snap/brave/642/.config/BraveSoftware/Brave-Browser
# BROWSER_EXECUTABLE_PATH=/snap/bin/brave
# Option 3: Connect to already-running Chrome (start with --remote-debugging-port=9222)
# BROWSER_WS_ENDPOINT=http://localhost:9222

# Behavior Settings
MIN_DELAY_SECONDS=5
MAX_DELAY_SECONDS=30
ACTIVE_HOURS_START=8
ACTIVE_HOURS_END=22
MAX_TWEETS_PER_SESSION=5
MAX_LIKES_PER_SESSION=20

# Persona
DEFAULT_PERSONA=tech_enthusiast
